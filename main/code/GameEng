using System; // basic

class GameController
{
    static Random rand = new Random();

    static void Main(string[] args)
    {
        Console.WriteLine("Enter your player name:");
        string playerName = Console.ReadLine();

        Player player = new Player(playerName);

        Console.WriteLine("\n🌌 Your journey into the unknown begins...\n");

        // Play Levels
        for (int i = 1; i <= 2; i++)
        {
            Level level = new Level(i);
            PlayLevel(player, level);

            if (player.Sanity <= 0)
                break;
        }

        // End Game
        if (player.Sanity > 0)
        {
            Console.WriteLine("\n🏆 You conquered all horrors and survived!");
        }
        else
        {
            Console.WriteLine("\n💀 You were consumed by the darkness...");
        }
    }

    static void PlayLevel(Player player, Level level)
    {
        level.StartLevel();

        while (level.HasEnemiesRemaining() && player.Sanity > 0)
        {
            level.ShowLevelProgress();

            Enemy enemy = level.SpawnEnemy();

            Console.WriteLine("\n⚠️ A new enemy appears!");
            enemy.DisplayInfo();

            Battle(player, enemy);

            if (player.Sanity > 0)
            {
                player.GainXP(50);
                GiveRandomReward(player);
            }
        }

        if (player.Sanity > 0)
        {
            level.CompleteLevel();
        }
    }

    static void Battle(Player player, Enemy enemy)
    {
        Console.WriteLine("\n⚔️ Battle Start!");

        // Special intro for boss
        if (enemy is Vecna vecna)
        {
            Console.WriteLine("\n👁️ Vecna has entered the battle...");
            vecna.GrandfatherClockSequence();
        }

        while (enemy.IsAlive() && player.Sanity > 0)
        {
            int choice = player.ChooseAction();

            switch (choice)
            {
                case 1:
                    player.Attack(enemy);
                    break;

                case 2:
                    player.SpecialAbility();
                    break;

                case 3:
                    player.UseItem();
                    break;

                case 4:
                    player.ShowStatus();
                    continue;

                case 5:
                    player.ShowInventory();
                    continue;

                default:
                    Console.WriteLine("Invalid choice!");
                    continue;
            }

            // Enemy Turn
            if (enemy.IsAlive())
            {
                Console.WriteLine("\n👿 Enemy's turn!");

                int damage;

                // Boss logic
                if (enemy is Vecna boss)
                {
                    if (rand.Next(100) < 50)
                    {
                        damage = boss.SpecialAttack();
                    }
                    else
                    {
                        damage = boss.Attack();
                    }

                    // Extra psychological attack
                    int sp = player.Sanity;
                    int hp = player.Sanity;

                    boss.PsychologicalAttack(ref sp, ref hp);

                    // update player after modification
                    player.Sanity = sp;
                }
                else
                {
                    // Normal enemies
                    if (rand.Next(100) < 30)
                    {
                        damage = enemy.SpecialAttack();
                    }
                    else
                    {
                        damage = enemy.Attack();
                    }
                }

                player.TakeSanityDamage(damage);
            }
        }

        if (!enemy.IsAlive())
        {
            Console.WriteLine("\n✅ Enemy defeated: " + enemy.GetName());

            // Boss victory scene
            if (enemy is Vecna boss)
            {
                boss.VictorySequence();
            }
        }
    }

    static void GiveRandomReward(Player player)
    {
        Console.WriteLine("\n🎁 You found an item!");

        string[] rewards = { "Health Potion", "Sanity Potion" };
        string item = rewards[rand.Next(rewards.Length)];

        player.AddItem(item);
    }
}
